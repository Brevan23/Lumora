# ---------------------------------------------------------------------------
# Lumora — environment variables. Copy to .env.local and fill in.
# ---------------------------------------------------------------------------

# Supabase — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — SERVER ONLY. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — use TEST keys while developing (Developers > API keys)
STRIPE_SECRET_KEY=
# Printed by `stripe listen` locally, or from the Dashboard webhook endpoint.
STRIPE_WEBHOOK_SECRET=

# Public base URL of the app (server-side: success/cancel URLs + admin email link).
# Local: http://localhost:3000 — Production: https://your-domain.com
APP_BASE_URL=http://localhost:3000

# Resend — transactional email (https://resend.com)
RESEND_API_KEY=
# Defaults to Resend's shared sender that works before domain verification.
# Any custom/unverified domain here is rejected with a 403.
EMAIL_FROM=onboarding@resend.dev
# Where the new-order alert is sent. In Resend test mode this MUST be your
# Resend account-owner email (the only address unverified sending reaches).
ADMIN_EMAIL=

# Admin login. Use a long, high-entropy random string (>= 24 chars).
ADMIN_PASSWORD=
# Required. HMAC-signs the admin session cookie; app fails closed if unset.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=

# Meta Pixel id. Leave empty to disable tracking (renders nothing, no errors).
NEXT_PUBLIC_META_PIXEL_ID=
